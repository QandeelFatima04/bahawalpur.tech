APP_NAME=CareerBridge AI API
ENV=dev
# Default dev DB: Postgres via docker-compose. For a purely local SQLite run,
# swap to: sqlite:///./careerbridge.db
DATABASE_URL=postgresql+psycopg2://careerbridge:careerbridge@localhost:5432/careerbridge
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=1440
REFRESH_TOKEN_MINUTES=43200
OPENAI_API_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=careerbridge-private
MAX_UPLOAD_SIZE_MB=5
ALLOWED_RESUME_EXTENSIONS=.pdf,.doc,.docx
